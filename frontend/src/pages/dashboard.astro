---
import Layout from '../layouts/Layout.astro';
import Sidebar from '../components/layout/Sidebar.astro';
import RiskChart from '../components/dashboard/RiskChart.jsx';
import TrendChart from '../components/dashboard/TrendChart.jsx';
import AlertsWidget from '../components/dashboard/AlertsWidget.jsx';
---
<Layout title="Dashboard">
  <div class="max-w-7xl mx-auto px-4 py-8">
    <div class="flex flex-col md:flex-row gap-6">
      <aside class="md:w-64"><Sidebar /></aside>
      <main class="flex-1 space-y-6">
        <div class="grid md:grid-cols-2 gap-6">
          <RiskChart client:only="react" />
          <TrendChart client:only="react" />
        </div>
        <AlertsWidget client:only="react" />
      </main>
    </div>
  </div>
</Layout>