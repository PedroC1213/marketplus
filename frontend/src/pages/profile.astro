---
import Layout from '../layouts/Layout.astro';
import Sidebar from '../components/layout/Sidebar.astro';
---
<Layout title="Mi perfil">
  <div class="max-w-7xl mx-auto px-4 py-8">
    <div class="flex flex-col md:flex-row gap-6">
      <aside class="md:w-64"><Sidebar /></aside>
      <main class="flex-1 glass-card p-6">
        <h1 class="text-2xl font-bold mb-4">Configuración de cuenta</h1>
        <form class="space-y-4 max-w-lg">
          <div><label class="block font-medium">Nombre</label><input type="text" class="w-full border rounded-lg p-2" placeholder="Tu nombre" /></div>
          <div><label class="block font-medium">Email</label><input type="email" class="w-full border rounded-lg p-2" value="moderador@marketplus.com" /></div>
          <div><label class="block font-medium">Nueva contraseña</label><input type="password" class="w-full border rounded-lg p-2" /></div>
          <button class="btn-primary">Guardar cambios</button>
        </form>
      </main>
    </div>
  </div>
</Layout>