---
const { variant = 'primary', size = 'md', href, class: className, ...props } = Astro.props;
const base = "inline-flex items-center justify-center font-semibold rounded-xl transition-all focus:outline-none focus:ring-2";
const variants = {
  primary: "bg-primary text-white hover:bg-primary/90 focus:ring-primary/50",
  secondary: "border border-primary text-primary hover:bg-primary/10 focus:ring-primary/50",
  danger: "bg-danger text-white hover:bg-danger/90 focus:ring-danger/50",
  ghost: "text-gray-600 hover:bg-gray-100 focus:ring-gray-300",
};
const sizes = {
  sm: "px-3 py-1.5 text-sm",
  md: "px-4 py-2",
  lg: "px-6 py-3 text-lg",
};
const Tag = href ? 'a' : 'button';
const attrs = href ? { href } : { type: 'button', ...props };
---

<Tag class={`${base} ${variants[variant]} ${sizes[size]} ${className ?? ''}`} {...attrs}>
  <slot />
</Tag>